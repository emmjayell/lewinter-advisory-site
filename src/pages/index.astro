---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import DoorCard from '../components/DoorCard.astro';
import PillarSolutionsCard from '../components/PillarSolutionsCard.astro';
import IndependenceStrip from '../components/IndependenceStrip.astro';
import { loadPage } from '../lib/loadPage';
import { pillars } from '../lib/pillars';
import { marked } from 'marked';
import twoPathsSvg from '../assets/graphics/two-paths.svg?raw';
import icebergSvg from '../assets/graphics/iceberg.svg?raw';
import frameworksVennSvg from '../assets/graphics/frameworks-venn.svg?raw';
import primeSvg from '../assets/graphics/advisory-led-prime.svg?raw';

interface Door {
  kicker: string;
  tone?: 'urgent' | 'calm';
  body: string;
  cta_label: string;
  cta_href: string;
  microcopy?: string;
}

interface PillarBlock {
  title: string;
  href: string;
  body: string;
}

interface HomeFrontmatter {
  title: string;
  meta_title: string;
  description: string;
  hero_eyebrow: string;
  hero_subhead: string;
  door_response: string;
  doors: Door[];
  problem: { heading: string; paragraphs: string[] };
  start: { heading: string; paragraphs: string[]; cta_label: string; cta_href: string };
  practice: {
    heading: string;
    lead: string;
    cta_label: string;
    cta_href: string;
    blocks: PillarBlock[];
  };
  why: { heading: string; paragraphs: string[] };
  final: {
    heading: string;
    body: string;
    primary_label: string;
    primary_href: string;
    secondary_label: string;
    secondary_href: string;
  };
}

const { frontmatter } = loadPage<HomeFrontmatter>('site-content/home.md');
const inline = (s: string) => marked.parseInline(s, { async: false }) as string;
---

<BaseLayout
  title={frontmatter.meta_title}
  ogTitle={frontmatter.title}
  description={frontmatter.description}
  titleOverride
>
  <!-- Hero + the two doors -->
  <section class="border-b border-rule">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
      <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,480px)]">
        <div>
          <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-soft">
            {frontmatter.hero_eyebrow}
          </span>
          <h1
            class="mt-6 text-[34px] font-semibold leading-[1.08] tracking-[-0.02em] text-ink sm:text-[46px] md:text-[58px]"
          >
            {frontmatter.title}
          </h1>
          <p class="mt-8 max-w-2xl text-[18px] leading-relaxed text-ink-muted sm:text-[20px]">
            {frontmatter.hero_subhead}
          </p>
        </div>
        <div class="illus mx-auto mt-8 w-full max-w-[480px] lg:mt-0">
          <Fragment set:html={twoPathsSvg} />
        </div>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {
          frontmatter.doors.map((door) => (
            <DoorCard
              kicker={door.kicker}
              body={door.body}
              cta_label={door.cta_label}
              cta_href={door.cta_href}
              microcopy={door.microcopy}
              tone={door.tone}
            />
          ))
        }
      </div>
      <p class="mt-5 text-[14px] text-ink-soft">
        Both doors lead to one point of contact. {frontmatter.door_response}
      </p>
    </div>
  </section>

  <!-- Section 2 - the problem nobody budgets for -->
  <section class="border-b border-rule bg-paper-soft">
    <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-24">
      <h2 class="text-[28px] font-semibold leading-tight tracking-tight text-ink sm:text-[34px]">
        {frontmatter.problem.heading}
      </h2>
      <div class="mt-6 space-y-5 text-[17px] leading-relaxed text-ink">
        {frontmatter.problem.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="illus diagram mt-12">
        <Fragment set:html={icebergSvg} />
      </div>
    </div>
  </section>

  <!-- Section 3 - start where you are -->
  <section class="border-b border-rule">
    <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-24">
      <h2 class="text-[28px] font-semibold leading-tight tracking-tight text-ink sm:text-[34px]">
        {frontmatter.start.heading}
      </h2>
      <div class="mt-6 space-y-5 text-[17px] leading-relaxed text-ink">
        {frontmatter.start.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      <div class="illus diagram mt-12">
        <Fragment set:html={frameworksVennSvg} />
      </div>
      <div class="mt-8">
        <CTA href={frontmatter.start.cta_href} label={frontmatter.start.cta_label} variant="link" />
      </div>
    </div>
  </section>

  <!-- Section 4 - what I do (four pillars) -->
  <section class="border-b border-rule">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-[28px] font-semibold leading-tight tracking-tight text-ink sm:text-[34px]">
          {frontmatter.practice.heading}
        </h2>
        <p class="mt-5 text-[17px] leading-relaxed text-ink-muted">
          {frontmatter.practice.lead}
        </p>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {pillars.map((pillar) => <PillarSolutionsCard pillar={pillar} variant="compact" />)}
      </div>

      <div class="mt-8">
        <CTA href={frontmatter.practice.cta_href} label={frontmatter.practice.cta_label} variant="link" />
      </div>
    </div>
  </section>

  <!-- Section 5 - why me -->
  <section class="border-b border-rule bg-paper-soft">
    <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-24">
      <h2 class="text-[28px] font-semibold leading-tight tracking-tight text-ink sm:text-[34px]">
        {frontmatter.why.heading}
      </h2>
      <div class="mt-6 space-y-5 text-[17px] leading-relaxed text-ink">
        {frontmatter.why.paragraphs.slice(0, 1).map((p) => <p set:html={inline(p)} />)}
      </div>
      <div class="illus diagram mt-10">
        <Fragment set:html={primeSvg} />
      </div>
      <div class="mt-6 space-y-5 text-[17px] leading-relaxed text-ink">
        {frontmatter.why.paragraphs.slice(1).map((p) => <p set:html={inline(p)} />)}
      </div>
      <div class="mt-10 border-t border-rule pt-6">
        <IndependenceStrip />
      </div>
    </div>
  </section>

  <!-- Section 6 - final CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 sm:py-24">
      <h2 class="text-[28px] font-semibold leading-tight tracking-tight text-ink sm:text-[34px]">
        {frontmatter.final.heading}
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-[17px] leading-relaxed text-ink-muted">
        {frontmatter.final.body}
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <CTA href={frontmatter.final.primary_href} label={frontmatter.final.primary_label} />
        <CTA
          href={frontmatter.final.secondary_href}
          label={frontmatter.final.secondary_label}
          variant="secondary"
        />
      </div>
    </div>
  </section>
</BaseLayout>
