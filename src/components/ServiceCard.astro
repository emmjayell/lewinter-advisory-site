---
interface Props {
  href: string;
  title: string;
  description: string;
  index?: number;
}

const { href, title, description, index } = Astro.props;
const label = typeof index === 'number' ? String(index + 1).padStart(2, '0') : undefined;
---

<a
  href={href}
  class="group flex flex-col justify-between gap-6 border-t border-rule py-8 transition-colors hover:border-ink"
>
  <div class="flex items-start gap-6">
    {
      label && (
        <span class="shrink-0 pt-1 text-[11px] font-medium uppercase tracking-[0.14em] text-ink-soft">
          {label}
        </span>
      )
    }
    <div class="flex-1">
      <h3
        class="text-[22px] font-semibold leading-snug tracking-tight text-ink md:text-[26px]"
      >
        {title}
      </h3>
      <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-ink-muted">
        {description}
      </p>
    </div>
    <span
      class="shrink-0 self-center text-ink-soft transition-transform group-hover:translate-x-1 group-hover:text-ink"
      aria-hidden="true"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path
          d="M4 10h12m0 0l-4.5-4.5M16 10l-4.5 4.5"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
  </div>
</a>
