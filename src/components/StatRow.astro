---
// A row of outcome stat tiles for /results engagement pages. Wraps to 2-up on
// mobile; sits on the ice background as hairline-bordered cards.
interface Stat {
  stat: string;
  line: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
const cols = stats.length >= 5 ? 'lg:grid-cols-5' : 'lg:grid-cols-4';
---

<div class={`grid grid-cols-2 gap-3 sm:gap-4 ${cols}`}>
  {
    stats.map((s) => (
      <div class="flex h-full flex-col rounded-2xl border border-[#E2EEEE] bg-[#F4FAFA] p-5">
        <p class="text-[22px] font-semibold leading-tight tracking-tight text-ink sm:text-[26px]">
          {s.stat}
        </p>
        <p class="mt-2 text-[13px] leading-snug text-ink-muted">{s.line}</p>
      </div>
    ))
  }
</div>
