---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadPage } from '../lib/loadPage';

interface PrivacyFrontmatter {
  title: string;
  description: string;
  last_updated?: string;
}

const { frontmatter, html } = loadPage<PrivacyFrontmatter>('site-content/privacy.md');
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <section>
    <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-24">
      <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-ink-soft">
        Privacy
      </p>
      <h1
        class="mt-4 text-[34px] font-semibold leading-tight tracking-tight text-ink sm:text-[40px]"
      >
        {frontmatter.title}
      </h1>
      {
        frontmatter.last_updated && (
          <p class="mt-3 text-[13px] text-ink-soft">
            Last updated: {frontmatter.last_updated}
          </p>
        )
      }

      <div class="prose-editorial mt-10" set:html={html} />
    </div>
  </section>
</BaseLayout>
