---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Headshot from '../components/Headshot.astro';
import { loadPage } from '../lib/loadPage';
import cisspBadge from '../assets/graphics/cert-badge-cissp.svg?raw';
import cmmcBadge from '../assets/graphics/cert-badge-cmmc-rp.svg?raw';
import vantaBadge from '../assets/graphics/cert-badge-vanta.svg?raw';

interface AboutFrontmatter {
  title: string;
  description: string;
  headshot: string;
  headshot_alt: string;
  headshot_size?: string;
  cta_label: string;
  cta_href: string;
}

const { frontmatter, html } = loadPage<AboutFrontmatter>('site-content/about.md');
---

<BaseLayout
  title="About Mike LeWinter, CISSP | LeWinter Advisory"
  description={frontmatter.description}
  titleOverride
>
  <section>
    <div class="mx-auto max-w-3xl px-5 py-20 sm:px-8 sm:py-24">
      <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-ink-soft">
        About
      </p>
      <h1
        class="mt-4 text-[34px] font-semibold leading-tight tracking-tight text-ink sm:text-[42px]"
      >
        {frontmatter.title}
      </h1>

      <div class="mt-10 flex items-center gap-5">
        <Headshot
          src={frontmatter.headshot}
          alt={frontmatter.headshot_alt}
          size={frontmatter.headshot_size === 'medium' ? 'medium' : 'small'}
        />
        <div>
          <p class="text-[15px] font-semibold tracking-tight text-ink">Mike LeWinter</p>
          <p class="text-[13px] text-ink-muted">Principal Consultant. CISSP.</p>
          <a
            href="https://linkedin.com/in/mikelewinter"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex items-center gap-1.5 text-[13px] font-medium text-accent-deep hover:text-ink"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"
              ></path>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Credential badges, side by side (stacked on mobile) -->
      <div class="mt-8">
        <div class="grid max-w-xl grid-cols-1 items-center gap-4 sm:grid-cols-3">
          <div class="badge" set:html={cisspBadge}></div>
          <div class="badge" set:html={cmmcBadge}></div>
          <div class="badge" set:html={vantaBadge}></div>
        </div>
        <p class="mt-3 max-w-xl text-[13px] leading-relaxed text-ink-soft">
          CISSP is the standard senior certification in information security. CMMC RP is the
          credential for guiding defense-supply-chain compliance. Verified Vanta Admin certifies
          hands-on command of the leading SOC 2 and ISO 27001 automation platform.
        </p>
      </div>

      <div class="prose-editorial mt-10" set:html={html} />

      <div class="mt-12">
        <CTA href={frontmatter.cta_href} label={frontmatter.cta_label} />
      </div>
    </div>
  </section>
</BaseLayout>
