---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  titleOverride?: boolean;
  jsonLd?: unknown[]; // page-specific structured data, appended to the site graph
}

const { title, description, ogImage, ogTitle, titleOverride, jsonLd = [] } = Astro.props;

// Site-wide structured data: who runs the practice and what it offers.
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://lewinteradvisory.com/#mike',
      name: 'Mike LeWinter',
      jobTitle: 'Principal Consultant',
      hasCredential: [
        { '@type': 'EducationalOccupationalCredential', name: 'CISSP' },
        { '@type': 'EducationalOccupationalCredential', name: 'CMMC Registered Practitioner' },
        { '@type': 'EducationalOccupationalCredential', name: 'Verified Vanta Admin' },
      ],
      sameAs: ['https://linkedin.com/in/mikelewinter'],
      worksFor: { '@id': 'https://lewinteradvisory.com/#org' },
    },
    {
      '@type': 'ProfessionalService',
      '@id': 'https://lewinteradvisory.com/#org',
      name: 'LeWinter Advisory LLC',
      url: 'https://lewinteradvisory.com',
      email: 'info@lewinteradvisory.com',
      telephone: '+1-805-619-9177',
      founder: { '@id': 'https://lewinteradvisory.com/#mike' },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'San Luis Obispo',
        addressRegion: 'CA',
        addressCountry: 'US',
      },
      areaServed: ['California', 'United States', 'Guam'],
      knowsAbout: [
        'Cybersecurity',
        'SOC 2',
        'CIS Controls',
        'NIST Cybersecurity Framework',
        'Incident Response',
        'Data Privacy',
        'Fractional CISO',
        'vCISO',
        'Operational Technology Security',
      ],
    },
  ],
};

const ldBlocks = [siteGraph, ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogTitle={ogTitle}
      titleOverride={titleOverride}
    />
    {
      ldBlocks.map((block) => (
        <script type="application/ld+json" set:html={JSON.stringify(block)} />
      ))
    }
  </head>
  <body class="min-h-screen bg-paper text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-ink focus:px-3 focus:py-2 focus:text-paper"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <StickyMobileCTA />
  </body>
</html>
