---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import PillarSolutionsCard from '../../components/PillarSolutionsCard.astro';
import { loadPage } from '../../lib/loadPage';
import { pillars } from '../../lib/pillars';
import engagementModelSvg from '../../assets/graphics/engagement-model.svg?raw';

interface ServicesIndexFrontmatter {
  title: string;
  description: string;
  common_thread: { heading: string; body: string; cta_label: string; cta_href: string };
}

const { frontmatter } = loadPage<ServicesIndexFrontmatter>('site-content/services/_index.md');
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <!-- Four pillars, each with its solutions directly beneath -->
  <section class="border-b border-rule bg-paper-soft">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-20">
      <h1 class="sr-only">Services</h1>
      <div class="grid gap-6 md:grid-cols-2">
        {pillars.map((pillar) => <PillarSolutionsCard pillar={pillar} />)}
      </div>
    </div>
  </section>

  <!-- One page-level CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:px-8 sm:py-24">
      <h2 class="text-[26px] font-semibold leading-tight tracking-tight text-ink sm:text-[32px]">
        {frontmatter.common_thread.heading}
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-relaxed text-ink-muted">
        {frontmatter.common_thread.body}
      </p>
      <div class="illus diagram mt-10">
        <Fragment set:html={engagementModelSvg} />
      </div>
      <div class="mt-10 flex justify-center">
        <CTA href={frontmatter.common_thread.cta_href} label={frontmatter.common_thread.cta_label} />
      </div>
    </div>
  </section>
</BaseLayout>
