---
interface Props {
  href: string;
  title: string;
  vertical: string;
  engagement_year?: string;
  service_line: string;
  serviceLabel?: string;
}

const { href, title, vertical, engagement_year, service_line, serviceLabel } = Astro.props;

const verticalLabel = vertical
  .split('-')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');
---

<a
  href={href}
  class="group flex flex-col gap-4 border-t border-rule py-8 transition-colors hover:border-ink"
>
  <div
    class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-medium uppercase tracking-[0.14em] text-ink-soft"
  >
    <span>{verticalLabel}</span>
    <span class="text-rule" aria-hidden="true">/</span>
    <span>{serviceLabel ?? service_line}</span>
    {
      engagement_year && (
        <>
          <span class="text-rule" aria-hidden="true">/</span>
          <span>{engagement_year}</span>
        </>
      )
    }
  </div>
  <h3
    class="max-w-3xl text-[22px] font-semibold leading-snug tracking-tight text-ink md:text-[28px]"
  >
    {title}
  </h3>
  <span
    class="mt-2 inline-flex items-center gap-2 text-[13px] font-medium tracking-tight text-accent-deep group-hover:text-ink"
  >
    View the capability
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path
        d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5"
        stroke="currentColor"
        stroke-width="1.25"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
</a>
