---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { loadPage } from '../../lib/loadPage';

interface ServicesIndexFrontmatter {
  title: string;
  description: string;
  cta_label: string;
  cta_href: string;
  service_order: string[];
}

const { frontmatter, html } = loadPage<ServicesIndexFrontmatter>(
  'site-content/services/_index.md',
);

const allServices = await getCollection('services', (e) => !e.data.draft);
const byKey = new Map(allServices.map((s) => [s.data.service_line ?? s.id, s]));
const ordered = (frontmatter.service_order as string[])
  .map((key) => byKey.get(key))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <section class="border-b border-rule">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-24">
      <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-ink-soft">
        Services
      </p>
      <h1
        class="mt-4 max-w-3xl text-[34px] font-semibold leading-tight tracking-tight text-ink sm:text-[44px]"
      >
        Five service lines across cybersecurity, compliance, architecture, and technology leadership.
      </h1>
      <div class="prose-editorial mt-8 max-w-2xl" set:html={html} />
      <div class="mt-10">
        <CTA href={frontmatter.cta_href} label={frontmatter.cta_label} />
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-20">
      {
        ordered.map((service, i) => (
          <ServiceCard
            href={`/services/${service.data.slug}`}
            title={service.data.title}
            description={service.data.description}
            index={i}
          />
        ))
      }
      <div class="border-t border-rule"></div>
    </div>
  </section>
</BaseLayout>
