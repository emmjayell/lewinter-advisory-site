---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const capabilities = await getCollection('capabilities', (e) => !e.data.draft);
  return capabilities.map((capability) => ({
    params: { slug: capability.data.slug },
    props: { capability },
  }));
}

const { capability } = Astro.props;
const { Content } = await render(capability);

const allServices = await getCollection('services', (e) => !e.data.draft);
const serviceBySlug = new Map(
  allServices.map((s) => [s.data.service_line, s.data]),
);

const primaryService = serviceBySlug.get(capability.data.service_line);
const secondaryService = capability.data.secondary_service_line
  ? serviceBySlug.get(capability.data.secondary_service_line)
  : undefined;

const verticalLabel = capability.data.vertical
  .split('-')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');
---

<BaseLayout
  title={capability.data.title}
  description={capability.data.description}
>
  <section class="border-b border-rule">
    <div class="mx-auto max-w-4xl px-5 py-20 sm:px-8 sm:py-24">
      <a
        href="/capabilities"
        class="text-[12px] font-medium uppercase tracking-[0.14em] text-ink-soft hover:text-ink"
      >
        &larr; Capabilities
      </a>

      <div
        class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-medium uppercase tracking-[0.14em] text-ink-soft"
      >
        {
          primaryService && (
            <>
              <span>{primaryService.title}</span>
              <span class="text-rule" aria-hidden="true">
                /
              </span>
            </>
          )
        }
        <span>Proof: {verticalLabel}</span>
        {
          capability.data.engagement_year && (
            <>
              <span class="text-rule" aria-hidden="true">
                /
              </span>
              <span>{capability.data.engagement_year}</span>
            </>
          )
        }
      </div>

      <h1
        class="mt-5 text-[30px] font-semibold leading-tight tracking-tight text-ink sm:text-[40px]"
      >
        {capability.data.title}
      </h1>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-20">
      <div class="prose-editorial">
        <Content />
      </div>

      <div class="mt-12 border-t border-rule pt-10">
        <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-ink-soft">
          Service lines
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            primaryService && (
              <a
                href={`/services/${primaryService.slug}`}
                class="rounded-full border border-rule px-3 py-1.5 text-[13px] text-ink hover:border-ink"
              >
                {primaryService.title}
              </a>
            )
          }
          {
            secondaryService && (
              <a
                href={`/services/${secondaryService.slug}`}
                class="rounded-full border border-rule px-3 py-1.5 text-[13px] text-ink hover:border-ink"
              >
                {secondaryService.title}
              </a>
            )
          }
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <CTA href="/contact" label="Scope an engagement" />
        <CTA href="/capabilities" label="See all capabilities" variant="link" />
      </div>
    </div>
  </section>
</BaseLayout>
